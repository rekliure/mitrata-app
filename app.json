{
  "expo": {
    "name": "Mitrata",
    "slug": "mitrata",
    "scheme": "mitrata",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mitrata.app"
    },
    "android": {
      "package": "com.mitrata.app",
      "adaptiveIcon": {
        "backgroundColor": "#f6efe3"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
